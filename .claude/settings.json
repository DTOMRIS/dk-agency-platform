{
  "protectedFiles": [
    "app/layout.tsx",
    "app/globals.css",
    "components/layout/Header.tsx",
    "components/layout/Footer.tsx",
    "components/layout/MobileBottomNav.tsx",
    "app/page.tsx",
    "app/haberler/page.tsx",
    "app/blog/page.tsx",
    "app/b2b-panel/page.tsx",
    "next.config.ts",
    "package.json",
    "tsconfig.json"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/block-dangerous.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/protect-files.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "PATH_INPUT=$(jq -r '.tool_input.file_path // empty'); [ -z \"$PATH_INPUT\" ] && exit 0; echo \"$PATH_INPUT\" | grep -qE '\\.(ts|tsx|js|jsx|json|css)$' || exit 0; npx prettier --write \"$PATH_INPUT\" 2>/dev/null || true",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/pre-commit-gate.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"additionalContext\": \"Branch: '$(git branch --show-current)' | Last commit: '$(git log -1 --format=%s)' | Read docs/LESSONS.md before any task.\"}'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
