# Cloudinary Image Upload
# Pulsuz hesab: https://cloudinary.com/users/register/free
# Dashboard → Cloud Name, API Key, API Secret kopyala
# Env var yoxdursa upload deaktivdir (graceful degradation, blob fallback)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME artıq lazım deyil — server-side upload
NEXTAUTH_URL=http://localhost:3000

# Seed passwords — override in production (NEVER commit real values)
ADMIN_SEED_PASSWORD=
MEMBER_SEED_PASSWORD=

# Resend Email
# https://resend.com/api-keys — API key al
# Sandbox: onboarding@resend.dev (yalnız öz email-inə göndərə bilir)
# Production: domain verify et → EMAIL_FROM=DK Agency <noreply@dkagency.az>
RESEND_API_KEY=
EMAIL_FROM=DK Agency <onboarding@resend.dev>
ADMIN_EMAIL=info@dkagency.az
NEXT_PUBLIC_SITE_URL=https://dkagency.az
HOSTNAME=0.0.0.0
# PORT is provided by Hostinger Node.js app. Do not hardcode it here.
